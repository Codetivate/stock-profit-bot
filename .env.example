# Copy to .env and fill in your real values. .env is gitignored.

# Required — from @BotFather
TELEGRAM_BOT_TOKEN=

# Optional — your personal chat_id (private DM) used for debug broadcasts and
# /profit replies. To send broadcasts to your own DM, put your personal
# chat_id here.
TELEGRAM_CHAT_ID=

# Optional — public channel chat_id for the broadcast fan-out (e.g. the
# numeric id of @earningsexclusive). When set, monitor.py and verify_one.py
# fan out chart messages to BOTH TELEGRAM_CHAT_ID (DM) and this channel.
TELEGRAM_CHANNEL_ID=

# Optional — admin chat_id that receives approval notifications for new users.
# If unset, the bot auto-approves everyone (current MVP behaviour).
TELEGRAM_ADMIN_CHAT_ID=

# Optional — when set to a truthy value, monitor.py also broadcasts plain
# news (no financial-statement zip) to Telegram. Default: off, so monitor
# only ships actual financial filings.
MONITOR_PUSH_NEWS=
