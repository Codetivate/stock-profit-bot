# Copy to .env and fill in your real values. .env is gitignored.

# Required — from @BotFather
TELEGRAM_BOT_TOKEN=

# Optional — channel chat_id for broadcast feature.
# To send broadcasts to your own DM instead of a channel, put your personal chat_id here.
TELEGRAM_CHAT_ID=

# Optional — admin chat_id that receives approval notifications for new users.
# If unset, the bot auto-approves everyone (current MVP behaviour).
TELEGRAM_ADMIN_CHAT_ID=
